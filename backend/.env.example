# Copy this file to `.env` (same folder as manage.py) and fill values.
# Never commit your real `.env`.

DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-render-service.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-render-service.onrender.com
DJANGO_SECRET_KEY=replace_with_a_long_random_secret
DJANGO_SECURE_SSL_REDIRECT=True

RAZORPAY_KEY_ID=replace_with_your_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_your_razorpay_key_secret
GOOGLE_CLIENT_ID=replace_with_your_google_client_id

# Optional integrations
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=replace_with_your_email_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your_email@example.com
FAST2SMS_API_KEY=your_fast2sms_key_here

# Render provides this automatically when you attach a PostgreSQL database.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Cloudinary persistent media storage for admin-uploaded vehicle images
# Easiest option: use CLOUDINARY_URL from Cloudinary dashboard
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Or use the three values below instead of CLOUDINARY_URL
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=royalwheels
