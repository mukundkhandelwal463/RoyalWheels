      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(django_http_responses_total_by_status_total[5m])), 1)",
          "legendFormat": "5xx"
        },
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"4..\"}[5m])) / clamp_min(sum(rate(django_http_responses_total_by_status_total[5m])), 1)",
